# ============================================================
# E-Commerce DDD Microservices Platform — Environment Template
# Copy this file to .env and fill in your own values.
# Never commit the real .env file to version control.
# ============================================================

# -- Deployment Environment (production | staging | development) --
ENVIRONMENT=production

# ============================================================
# Legacy Resilience Demo Credentials (docker-compose.resilience-demo.yml)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=system_design

# Redis (Resilience Demo)
REDIS_PASSWORD=change_me_redis_password

# ============================================================
# E-Commerce Microservice Database Credentials
# Each service has its own isolated PostgreSQL database.
# ============================================================

# User Service DB
USER_DB_NAME=user_db
USER_DB_USER=postgres
USER_DB_PASSWORD=change_me_user_db_password
USER_DB_HOST_PORT=5432

# Product Service DB
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=postgres
PRODUCT_DB_PASSWORD=change_me_product_db_password
PRODUCT_DB_HOST_PORT=5433

# Order Service DB
ORDER_DB_NAME=order_db
ORDER_DB_USER=postgres
ORDER_DB_PASSWORD=change_me_order_db_password
ORDER_DB_HOST_PORT=5434

# Shared Redis Cache (idempotency key store — shared across all services)
# REDIS_PASSWORD already defined above; reuse same value here.

# ============================================================
# Microservice Listen Ports (host-side port mappings)
# ============================================================
USER_SERVICE_PORT=8001
PRODUCT_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003

# ============================================================
# Apache Kafka (KRaft mode — no Zookeeper required)
# ============================================================
# Internal Docker network listener used by services inside containers
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# Host-facing port (for local Kafka tooling / debugging from the host)
KAFKA_HOST_PORT=9092

# ============================================================
# Observability
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
