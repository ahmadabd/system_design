  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Webhook Dispatch Throughput (Attempts/sec)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(webhook_delivery_attempts_total[1m])) by (store_id, success)",
          "legendFormat": "Store {{store_id}} (Success: {{success}})",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Store Webhook Circuit Breaker Status (0=CLOSED, 1=OPEN, 2=HALF-OPEN)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "circuit_breaker_state{name=~\"store-webhook-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Webhook Delivery Latency (Seconds)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(webhook_delivery_duration_seconds_sum[1m])) by (store_id) / sum(rate(webhook_delivery_duration_seconds_count[1m])) by (store_id)",
          "legendFormat": "Store {{store_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Topic Partition Pause Events Count",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(webhook_partition_pauses_total) by (store_id, partition)",
          "legendFormat": "Store {{store_id}} (Partition {{partition}})",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "webhooks",
    "resilience"
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "title": "Store Webhook & Partition Isolation Monitoring",
  "uid": "webhook-partition-monitoring"
}
