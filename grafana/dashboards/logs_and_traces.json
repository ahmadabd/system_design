      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{service_name=~\"$service_name\"}",
          "refId": "A"
        }
      ],
      "title": "Application Logs",
      "type": "logs"
